{
  "name": "youtube-commander",
  "version": "1.0.0",
  "description": "Take full command of your YouTube experience with quality control, custom navigation, and playback features.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"src/**/*.css\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "@types/webextension-polyfill": "^0.10.0",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-web-extension": "^4.0.0",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.10.0"
  },
  "keywords": [
    "chrome-extension",
    "youtube",
    "video-controls",
    "browser-extension"
  ],
  "author": "Your Name",
  "license": "MIT",
  "lint-staged": {
    "*.js": ["eslint --fix", "prettier --write"],
    "*.css": ["prettier --write"]
  }
}
